# Required for AI interview (Google Gemini). Kept server-side via Vite proxy in dev/preview.
# Create a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Primary model (optional). Used when VITE_GEMINI_MODELS is not set.
GEMINI_MODEL=gemini-2.5-flash-lite

# Comma- or space-separated fallback models (client tries in order on quota / rate limit).
# First successful model is remembered for the session (sessionStorage).
# Example:
# VITE_GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash,gemini-1.5-flash
VITE_GEMINI_MODELS=

# Optional: override API path prefix (default /api/gemini)
# VITE_GEMINI_API_ROOT=/api/gemini

# Optional: single custom backend URL (bypasses multi-model proxy)
# VITE_GEMINI_GENERATE_URL=https://example.com/gemini
